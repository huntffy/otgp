# Copy to .env and change every secret before running anything you care about.
# .env is git-ignored; .env.example is not.

# --- Postgres -----------------------------------------------------------------
# POSTGRES_USER owns the schema and runs migrations.
#
# Port 5433, not 5432: a locally-installed Postgres binds 127.0.0.1:5432 explicitly
# while Docker binds *:5432. Both succeed, and `localhost` reaches the local one.
POSTGRES_DB=otgp
POSTGRES_USER=otgp
POSTGRES_PASSWORD=change-me-owner
POSTGRES_PORT=5433

# APP_DB_USER is the unprivileged role the API connects as. Row-Level Security
# is only enforced for this role; the owner and any superuser bypass it.
APP_DB_USER=otgp_app
APP_DB_PASSWORD=change-me-app

# Runtime connection (unprivileged role, RLS enforced).
OTGP_DATABASE_URL=postgresql+psycopg://otgp_app:change-me-app@localhost:5433/otgp

# Migration connection (schema owner, RLS bypassed via FORCE-exempt DDL).
OTGP_MIGRATION_DATABASE_URL=postgresql+psycopg://otgp:change-me-owner@localhost:5433/otgp

# --- Redis --------------------------------------------------------------------
REDIS_PORT=6379
OTGP_REDIS_URL=redis://localhost:6379/0

# --- MinIO --------------------------------------------------------------------
MINIO_ROOT_USER=otgp-minio
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
OTGP_S3_ENDPOINT_URL=http://localhost:9000
OTGP_S3_BUCKET=otgp

# --- Application --------------------------------------------------------------
OTGP_ENVIRONMENT=local
OTGP_DEBUG=true
